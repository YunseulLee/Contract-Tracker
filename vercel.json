{
  "crons": [
    {
      "path": "/api/confluence-sync?mode=incremental&year=2026",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron?mode=weekly",
      "schedule": "0 1 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
